# ============================================
# MySQL 数据库配置
# ============================================
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=users
MYSQL_USER=test
MYSQL_PASSWORD=test1234
MYSQL_PORT=3307

# ============================================
# API 服务配置
# ============================================
NODE_ENV=development
API_PORT=3000
API_HOST_PORT=3003
API_HOST=localhost:3003

# 数据库连接配置（API 服务使用）
DB_HOST=db
DB_PORT=3306
DB_NAME=users
DB_USER=test
DB_PASSWORD=test1234

# JWT 密钥（生产环境请使用强随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# CORS 允许的来源（逗号分隔，无空格）
# 例如：http://localhost:3031,http://example.com,https://app.example.com
CORS_ORIGINS=http://localhost:3031,http://localhost:3000

# ============================================
# 前端客户端配置
# ============================================
# 前端访问的 API 地址（需要是浏览器能访问到的地址）
# 本地开发：http://localhost:3003
# 生产环境：https://api.example.com
REACT_APP_API_URL=http://localhost:3003
CLIENT_HOST_PORT=3031
